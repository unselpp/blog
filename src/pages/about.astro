---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="About">
  <h1>About</h1>
  
  <p>
    This is a minimal blog built with Astro, Markdown, and Shiki. 
    It features a clean, readable design with a focus on typography and content.
  </p>
  
  <p>
    Write your posts in Markdown files in the <code>src/content/blog/</code> directory.
    The blog automatically renders code blocks, quotations, bullet points, and more.
  </p>
  
  <p>
    Feel free to customize this page with your own information, bio, and links.
  </p>
</BlogLayout>
