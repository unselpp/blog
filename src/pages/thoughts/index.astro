---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const thoughtPosts = (await getCollection('thoughts')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BlogLayout title="Thoughts">
  <h1>Thoughts</h1>
  <p>Short notes, half-formed ideas, and quick updates.</p>

  <ul class="post-list">
    {thoughtPosts.map((post) => (
      <li>
        <a href={`/thoughts/${post.slug}`}>
          <h3>{post.data.title || 'Untitled thought'}</h3>
          <span class="post-date">
            {post.data.pubDate.toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric'
            })}
          </span>
        </a>
      </li>
    ))}
  </ul>
</BlogLayout>
